{
  "name": "skyguin-meblox",
  "type": "module",
  "version": "1.0.0",
  "description": "Aplikacja do projektowania mebli",
  "scripts": {
    "dev": "bun run server/index.ts",
    "dev:ui": "vite --config client/vite.config.ts",
    "build": "bun run typecheck && vite build --config client/vite.config.ts",
    "preview": "vite preview --config client/vite.config.ts",
    "start": "bun run server/index.ts",
    "start-debug": "LOG_LEVEL=debug bun run server/index.ts",
    "typecheck": "bun run typecheck:ts && bun run typecheck:vue",
    "typecheck:ts": "bunx tsc --noEmit --project tsconfig.json",
    "typecheck:vue": "vue-tsc --project tsconfig.json --noEmit",
    "lint": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write .",
    "test": "bun test",
    "test:run": "bun test --bail",
    "verify:start": "bun run build && bun run scripts/verify-start.ts",
    "prepare": "husky"
  },
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "^1.3.10",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "bun-types": "^1.3.10",
    "husky": "^9.1.7",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vue-tsc": "^3.2.5"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "three": "^0.183.2",
    "vue": "^3.5.30",
    "zod": "^4.3.6"
  }
}
