{
  "name": "skyguin-meblox",
  "type": "module",
  "version": "1.0.0",
  "description": "Aplikacja do projektowania mebli",
  "scripts": {
    "dev": "bun run server/index.ts",
    "dev:ui": "bun run --cwd client dev",
    "build": "bun run --cwd client build",
    "start": "bun run server/index.ts",
    "typecheck": "bun run typecheck:server && bun run typecheck:client",
    "typecheck:server": "bunx tsc --noEmit --project tsconfig.server.json",
    "typecheck:client": "bun run --cwd client typecheck",
    "lint": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write .",
    "test": "bun test",
    "test:run": "bun test --bail",
    "verify:start": "bun run build && bun run scripts/verify-start.ts",
    "prepare": "husky",
    "install:all": "bun install && bun install --cwd client"
  },
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "bun-types": "^1.3.10"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "^1.3.10",
    "@types/three": "^0.183.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.5",
    "zod": "^4.3.6"
  }
}
